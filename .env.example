# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jadeassist
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4-turbo
LLM_TOKEN_LIMIT=4000

# Auth (hook into eventflow or use standalone)
JWT_SECRET=your-secret-key
AUTH_PROVIDER=jwt

# Event-flow integration
EVENTFLOW_API_URL=https://event-flow.co.uk/api
EVENTFLOW_API_KEY=optional-key

# EventFlow Catalog API (protected) — required for venue/supplier search
# Option 1: catalog endpoints on the main EventFlow domain
EVENTFLOW_CATALOG_BASE_URL=https://event-flow.co.uk
# API key sent as X-Catalog-Api-Key header on every catalog request
EVENTFLOW_CATALOG_API_KEY=your-catalog-api-key

# CORS — set to '*' to allow all origins (default for local dev), or a comma-separated
# list of allowed origins for production.
# Production (EventFlow):
#   CORS_ORIGIN=https://event-flow.co.uk,https://www.event-flow.co.uk
# Development (all origins):
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
