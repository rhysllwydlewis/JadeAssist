# Redirect npm's cache away from node_modules/.cache so that BuildKit cache
# mounts (used by Nixpacks/Railway) do not hold a lock on a sub-directory that
# `npm ci` tries to delete when it clears node_modules.  Without this, a
# --mount=type=cache targeting /app/node_modules/.cache causes an EBUSY /
# ENOTEMPTY error the moment npm ci attempts to remove that directory.
cache=/tmp/npm-cache
